{
  "name": "ibynn-target-scraper",
  "version": "1.0.0",
  "description": "A web scraper for Target search results with local and Bright Data browser support",
  "main": "src/scraper.js",
  "bin": {
    "ibynn-scrape": "src/cli.js",
    "ibynn-amazon-fresh-scrape": "src/amazon-fresh-cli.js",
    "ibynn-costco-scrape": "src/costco-cli.js",
    "ibynn-walmart-scrape": "src/walmart-cli.js"
  },
  "files": [
    "src/",
    "config.js"
  ],
  "scripts": {
    "start": "node src/cli.js",
    "scrape": "node src/cli.js",
    "test": "node examples/test.js",
    "advanced": "node examples/advanced.js",
    "batch": "node examples/batch.js",
    "amazonfresh:scrape": "node src/amazon-fresh-cli.js",
    "costco:local": "node examples/costco-local-headful.js",
    "costco:scrape": "node src/costco-cli.js",
    "walmart:scrape": "node src/walmart-cli.js",
    "debug": "node debug.js"
  },
  "keywords": [
